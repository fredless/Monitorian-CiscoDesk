<UserControl x:Class="Monitorian.Core.Views.CiscoDeskSection"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:behaviors="clr-namespace:Monitorian.Core.Views.Behaviors"
			 xmlns:controls="clr-namespace:Monitorian.Core.Views.Controls"
			 xmlns:properties="clr-namespace:Monitorian.Core.Properties"
			 mc:Ignorable="d">
	<StackPanel>
		<Separator Style="{StaticResource MenuSeparatorStyle}"/>

		<ContentControl Style="{StaticResource MenuItemStyle}">
			<ToggleButton Padding="8,4"
						  Style="{StaticResource CheckButtonItemStyle}"
						  Content="{x:Static properties:Invariant.CiscoDeskEnable}"
						  IsChecked="{Binding Settings.EnablesCiscoDesk}"/>
		</ContentControl>

		<ContentControl Style="{StaticResource MenuItemStyle}">
			<controls:MultiToggleButton Padding="8,4"
										Style="{StaticResource MultiButtonItemStyle}"
										Content="{x:Static properties:Invariant.CiscoDeskSettings}"
										IsCheckable="False">
				<controls:MultiToggleButton.SubContent>
					<StackPanel>
						<TextBlock Style="{StaticResource PlainTextStyle}"
								   Text="{x:Static properties:Invariant.CiscoDeskHost}"/>
						<TextBox Style="{StaticResource PlainTextBoxStyle}"
								 FlowDirection="LeftToRight"
								 MaxLength="253" Margin="0,1,0,4"
								 Text="{Binding Settings.CiscoDeskHost, Mode=TwoWay}">
							<i:Interaction.Triggers>
								<i:EventTrigger SourceObject="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}}" EventName="Closed">
									<behaviors:UpdateSourceAction/>
								</i:EventTrigger>
							</i:Interaction.Triggers>
						</TextBox>

						<TextBlock Style="{StaticResource PlainTextStyle}"
								   Text="{x:Static properties:Invariant.CiscoDeskUsername}"/>
						<TextBox Style="{StaticResource PlainTextBoxStyle}"
								 FlowDirection="LeftToRight"
								 MaxLength="128" Margin="0,1,0,4"
								 Text="{Binding Settings.CiscoDeskUsername, Mode=TwoWay}">
							<i:Interaction.Triggers>
								<i:EventTrigger SourceObject="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}}" EventName="Closed">
									<behaviors:UpdateSourceAction/>
								</i:EventTrigger>
							</i:Interaction.Triggers>
						</TextBox>

						<TextBlock Style="{StaticResource PlainTextStyle}"
								   Text="{x:Static properties:Invariant.CiscoDeskPassword}"/>
						<PasswordBox x:Name="PasswordBox"
									 FlowDirection="LeftToRight"
									 MaxLength="128" Margin="0,1,0,4"
									 FontSize="12"
									 Foreground="{StaticResource App.Foreground}"
									 CaretBrush="{StaticResource App.Foreground}"
									 Background="{DynamicResource App.Background.Plain}"
									 BorderBrush="{DynamicResource App.Border.Outline}" BorderThickness="1"/>

						<ToggleButton Padding="0,2"
									  Style="{StaticResource CheckButtonItemStyle}"
									  FontSize="12"
									  Content="{x:Static properties:Invariant.CiscoDeskUsesHttps}"
									  IsChecked="{Binding Settings.CiscoDeskUsesHttps}"/>

						<ToggleButton Padding="0,2"
									  Style="{StaticResource CheckButtonItemStyle}"
									  FontSize="12"
									  Content="{x:Static properties:Invariant.CiscoDeskValidatesCertificate}"
									  IsChecked="{Binding Settings.CiscoDeskValidatesCertificate}"/>

						<Button Padding="0,2"
								Style="{StaticResource PlainButtonItemStyle}"
								FontSize="12"
								Content="{x:Static properties:Invariant.CiscoDeskTest}"
								IsEnabled="{Binding CanTest, Mode=OneWay}">
							<i:Interaction.Triggers>
								<i:EventTrigger EventName="Click">
									<i:CallMethodAction TargetObject="{Binding}"
														MethodName="PerformTest"/>
								</i:EventTrigger>
							</i:Interaction.Triggers>
						</Button>

						<TextBlock Style="{StaticResource PlainTextStyle}"
								   TextWrapping="Wrap"
								   Text="{Binding TestResult, Mode=OneWay}"
								   Visibility="{Binding TestResult, Mode=OneWay, Converter={StaticResource ObjectToVisibilityConverterKey}}"/>
					</StackPanel>
				</controls:MultiToggleButton.SubContent>
			</controls:MultiToggleButton>
		</ContentControl>
	</StackPanel>
</UserControl>
